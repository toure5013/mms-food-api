		{
			"name": "🔐 Auth",
			"description": "Authentification JWT + OTP. Toutes les routes sont publiques (pas de token requis).",
			"item": [
				{
					"name": "Login (Email + Password)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.access_token) {",
									"        pm.collectionVariables.set('token', jsonData.access_token);",
									"        console.log('✅ Token sauvegardé automatiquement');",
									"    }",
									"    if (jsonData.refresh_token) {",
									"        pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
									"    }",
									"    if (jsonData.user && jsonData.user.id) {",
									"        pm.collectionVariables.set('user_id', jsonData.user.id);",
									"    }",
									"    if (jsonData.user && jsonData.user.organisation_id) {",
									"        pm.collectionVariables.set('org_id', jsonData.user.organisation_id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@mms.ci\",\n    \"password\": \"admin123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Connexion avec email et mot de passe. Retourne un JWT access_token.\n\nLe token est automatiquement sauvegardé dans les variables de la collection."
					},
					"response": []
				},
				{
