# App
NODE_ENV=development
PORT=3001
APP_NAME=MMS API

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mms_db
DB_USER=postgres
DB_PASS=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=super_secret_change_in_production
JWT_EXPIRES_IN=30d

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM=noreply@matinmidisoir.ci

# Firebase
FIREBASE_SERVICE_ACCOUNT_KEY={}

# Storage (S3/R2)
S3_ENDPOINT=
S3_BUCKET=mms-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=

# OTP
OTP_EXPIRY_MINUTES=10

# Logging
LOG_TARGETS=terminal,file
LOG_LEVEL=info
DB_LOG_QUERIES=false
ELASTICSEARCH_NODE=http://localhost:9200
